source /usr/share/zinit/zinit.zsh

# --- 1. Instant Load (Prompt Essentials) ---
zinit snippet OMZP::starship

# --- 2. Turbo Mode (Deferred Load) ---
zinit snippet OMZP::git
zinit light djui/alias-tips
zinit light hlissner/zsh-autopair

# Completion Engine Optimization
zinit light zsh-users/zsh-completions

# History Search
zinit light zsh-users/zsh-history-substring-search
zinit load zdharma-continuum/history-search-multi-word

# --- 3. Initialize Completion System ---
# Use the -C flag to skip the expensive security check on every start
autoload -Uz compinit
compinit -C

# --- 4. UI Plugins (Must load after compinit) ---
zinit light Aloxaf/fzf-tab
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting
