if hiarchy-cmd-present mise; then
  eval "$(mise activate zsh)"
fi

if hiarchy-cmd-present starship; then
  eval "$(starship init zsh)"
fi

if hiarchy-cmd-present zoxide; then
  eval "$(zoxide init zsh)"
fi

if hiarchy-cmd-present try; then
  eval "$(try init ~/Work/tries)"
fi

if hiarchy-cmd-present fzf; then
  eval "$(fzf --zsh)"
fi

if hiarchy-cmd-present kubectl; then
  source <(kubectl completion zsh)
fi
