#!/bin/bash

# Creates a new Hiarchy migration named after the unix timestamp of the last commit.
# Only intended for Hiarchy developers.

cd ~/.local/share/hiarchy
migration_file="$HOME/.local/share/hiarchy/migrations/$(git log -1 --format=%cd --date=unix).sh"
touch $migration_file

if [[ "$1" != "--no-edit" ]]; then
  nvim $migration_file
fi

echo $migration_file
