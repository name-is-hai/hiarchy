#!/bin/bash

set -e

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://hiarchy.org/discord\033[0m";hiarchy-snapshot delete' ERR

if [[ $1 == "-y" ]] || hiarchy-update-confirm; then
  hiarchy-snapshot create || [ $? -eq 127 ]
  hiarchy-update-git
  hiarchy-update-perform
fi
