#!/bin/bash

# Refreshes a specific config file or folder
# Usage: hiarchy-refresh-config hypr/hypridle.conf

path_arg=$1

if [[ -z "$path_arg" ]]; then
  echo "Usage: $0 [relative_path]"
  exit 1
fi

HIARCHY_PATH="${HIARCHY_PATH:-$HOME/.local/share/hiarchy}"
CONFIG_DIR="$HIARCHY_PATH/config"
TARGET_BASE="$HOME/.config"

# --- Determine if we are refreshing a Folder or a File ---
source_path="$CONFIG_DIR/$path_arg"
target_path="$TARGET_BASE/$path_arg"

if [[ ! -e "$source_path" ]]; then
    echo -e "\e[31mError: $source_path not found.\e[0m"
    exit 1
fi

if [[ -d "$source_path" ]]; then
    # If it's a directory, use GNU Stow for the whole folder
    echo "Restowing directory: $path_arg"
    stow -R -v --no-folding -t "$TARGET_BASE" -d "$CONFIG_DIR" "$path_arg"
else
    # If it's a specific file, ensure the target directory exists and link it
    echo "Linking specific file: $path_arg"

    # Backup if it's a real file, not a link
    if [[ -f "$target_path" && ! -L "$target_path" ]]; then
        mv "$target_path" "$target_path.bak.$(date +%s)"
    fi

    mkdir -p "$(dirname "$target_path")"
    ln -snf "$source_path" "$target_path"
fi

echo -e "\e[32mSuccessfully refreshed $path_arg\e[0m"
