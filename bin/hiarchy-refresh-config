#!/bin/bash

# Symlinks the named config component from ~/.local/share/hiarchy/default/ to ~/.config/ using GNU Stow.
# If the config already exists and is not a link, a backup will be taken as .bak.TIMESTAMP.

config_file=$1

if [[ -z "$config_file" ]]; then
  cat <<USAGE
  Usage: $0 [config_file]

  Must provide a file path or directory from the .config directory to be refreshed.
  Example: To refresh hyprland configs:
    $0 hypr/hyprland.conf
USAGE
  exit 1
fi

HIARCHY_PATH="${HIARCHY_PATH:-$HOME/.local/share/hiarchy}"
DEFAULT_DIR="$HIARCHY_PATH/default"
TARGET_CONFIG="$HOME/.config"

# Identify the "package" (top-level directory or file name)
PACKAGE=$(echo "$config_file" | cut -d/ -f1)

if [[ ! -e "$DEFAULT_DIR/$PACKAGE" ]]; then
  echo "Error: Package '$PACKAGE' not found in $DEFAULT_DIR"
  exit 1
fi

# Backup existing if it's a real directory/file to avoid Stow conflicts
target="$TARGET_CONFIG/$PACKAGE"
if [[ -e "$target" && ! -L "$target" ]]; then
  backup="$target.bak.$(date +%s)"
  echo "Backing up existing: $target -> $backup"
  mv "$target" "$backup"
fi

echo "Refreshing '$PACKAGE' configuration..."
stow -R -v --no-folding -t "$TARGET_CONFIG" -d "$DEFAULT_DIR" "$PACKAGE"
