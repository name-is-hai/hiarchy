#!/bin/bash

# Launch a floating terminal with the Hiarchy logo presentation, then execute the command passed in, and finally end with the hiarchy-show-done presentation.
# Used by actions such as Update System.

cmd="$*"
exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.hiarchy.terminal --title=Hiarchy -e bash -c "hiarchy-show-logo; $cmd; if [ \$? -ne 130 ]; then hiarchy-show-done; fi"
