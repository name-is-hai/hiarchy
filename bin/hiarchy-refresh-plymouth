#!/bin/bash

# Overwrite the user config for the Plymouth drive decryption and boot sequence with the Hiarchy default and rebuild it.

sudo cp ~/.local/share/hiarchy/default/plymouth/* /usr/share/plymouth/themes/hiarchy/
sudo plymouth-set-default-theme hiarchy

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
