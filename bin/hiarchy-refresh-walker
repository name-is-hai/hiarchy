#!/bin/bash

# Overwrite the user configs for the Walker application launcher (which also powers the Hiarchy Menu) and restart the services.

# Ensure walker is set to autostart
mkdir -p ~/.config/autostart/
ln -sf $HIARCHY_PATH/default/walker/walker.desktop ~/.config/autostart/

# And restarts if it crashes or is killed
mkdir -p ~/.config/systemd/user/app-walker@autostart.service.d/
ln -sf $HIARCHY_PATH/default/walker/restart.conf ~/.config/systemd/user/app-walker@autostart.service.d/restart.conf

systemctl --user daemon-reload

# Refresh configs using Stow
hiarchy-refresh-config walker/
hiarchy-refresh-config elephant/

# Restart service
hiarchy-restart-walker
