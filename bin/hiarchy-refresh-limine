#!/bin/bash

# Overwrite the user config for the Limine bootloader and rebuild it.

if [[ -f /boot/EFI/Linux/hiarchy_linux.efi ]] && [[ -f /boot/EFI/Linux/$(cat /etc/machine-id)_linux.efi ]]; then
  echo "Cleanup extra UKI"
  sudo rm -f /boot/EFI/Linux/$(cat /etc/machine-id)_linux.efi
fi
echo "Resetting limine config"

sudo mv /boot/limine.conf /boot/limine.conf.bak

# Try to symlink first, fallback to copy if /boot is vfat
sudo ln -sf ~/.local/share/hiarchy/default/limine/limine.conf /boot/limine.conf 2>/dev/null || \
  sudo cp ~/.local/share/hiarchy/default/limine/limine.conf /boot/limine.conf

sudo limine-update
sudo limine-snapper-sync
