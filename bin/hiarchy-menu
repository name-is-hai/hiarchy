#!/bin/bash

# Launch the Hiarchy Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/hiarchy/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | hiarchy-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptŌĆ”" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.hiarchy.terminal "$@"
}

present_terminal() {
  hiarchy-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  hiarchy-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm --needed $2 && sleep 2 && hiarchy-font-set '$3'"
}

show_learn_menu() {
  case $(menu "Learn" "’ä£  Keybindings\n’ŹÖ  Hyprland\n¾░Żć  Arch\nŅÜ«  Neovim\n¾▒åā  Bash") in
  *Keybindings*) hiarchy-menu-keybindings ;;
  *Hyprland*) hiarchy-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) hiarchy-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) hiarchy-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) hiarchy-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "’Ć░  Capture\n’öÄ  Share\n¾░öÄ  Toggle\nŅĮ░  Hardware") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "’Ć░  Screenshot\n’ĆĮ  Screenrecord\n¾░āē  Color") in
  *Screenshot*) show_screenshot_menu ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) show_trigger_menu ;;
  esac
}

show_screenshot_menu() {
  case $(menu "Screenshot" "’Ć░  Snap with Editing\n’Ć░  Straight to Clipboard") in
  *Editing*) hiarchy-cmd-screenshot smart ;;
  *Clipboard*) hiarchy-cmd-screenshot smart clipboard ;;
  *) show_capture_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ "$line" != $'\t'* && -n "$line" ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n "$device" ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z "$devices" || "$count" -eq 0 ]]; then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if [[ "$count" -eq 1 ]]; then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  hiarchy-cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "’ĆĮ  With desktop audio\n’ĆĮ  With desktop + microphone audio\n’ĆĮ  With desktop + microphone audio + webcam") in
  *"With desktop audio") hiarchy-cmd-screenrecord --with-desktop-audio ;;
  *"With desktop + microphone audio") hiarchy-cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || { back_to show_capture_menu; return; }
    hiarchy-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "’ü┐  Clipboard\nŅ®╗  File \n’äö  Folder") in
  *Clipboard*) hiarchy-cmd-share clipboard ;;
  *File*) terminal bash -c "hiarchy-cmd-share file" ;;
  *Folder*) terminal bash -c "hiarchy-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "¾▒ää  Screensaver\n¾░öÄ  Nightlight\n¾▒½¢  Idle Lock\n¾░Ź£  Top Bar") in
  *Screensaver*) hiarchy-toggle-screensaver ;;
  *Nightlight*) hiarchy-toggle-nightlight ;;
  *Idle*) hiarchy-toggle-idle ;;
  *Bar*) hiarchy-toggle-waybar ;;
  *) show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  case $(menu "Toggle" "Ņ░Ö  Hybrid GPU") in
  *"Hybrid GPU"*) present_terminal hiarchy-toggle-hybrid-gpu ;;
  *) show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "¾░Ėī  Theme\nŅÖÖ  Font\n’ĆŠ  Background\n’ŹÖ  Hyprland\n¾▒ää  Screensaver\nŅ®┤  About") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) hiarchy-theme-bg-next ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *Screensaver*) open_in_editor ~/.config/hiarchy/branding/screensaver.txt ;;
  *About*) open_in_editor ~/.config/hiarchy/branding/about.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  hiarchy-launch-walker -m menus:hiarchythemes --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(hiarchy-font-list)" "--width 350" "$(hiarchy-font-current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    hiarchy-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="ŅśĖ  Audio\n’ć½  Wifi\n¾░é»  Bluetooth\n¾▒Éŗ  Power Profile\n’Ćæ  System Sleep\n¾░Ź╣  Monitors"
  [ -f ~/.config/hypr/bindings.conf ] && options="$options\n’ä£  Keybindings"
  [ -f ~/.config/hypr/input.conf ] && options="$options\nŅŠ║  Input"
  options="$options\n¾░▒ö  DNS\nŅ¼æ  Security\nŅśĢ  Config"

  case $(menu "Setup" "$options") in
  *Audio*) hiarchy-launch-audio ;;
  *Wifi*) hiarchy-launch-wifi ;;
  *Bluetooth*) hiarchy-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Monitors*) open_in_editor ~/.config/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/hypr/bindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *DNS*) present_terminal hiarchy-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(hiarchy-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ "$profile" == "CNCLD" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_security_menu() {
  case $(menu "Setup" "¾░łĘ  Fingerprint\nŅ¼æ  Fido2") in
  *Fingerprint*) present_terminal hiarchy-setup-fingerprint ;;
  *Fido2*) present_terminal hiarchy-setup-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "’Æē  Defaults\n’ŹÖ  Hyprland\n’ŹÖ  Hypridle\n’ŹÖ  Hyprlock\n’ŹÖ  Hyprsunset\n’ŹØ  Swayosd\n¾░ī¦  Walker\n¾░Ź£  Waybar\n¾░×ģ  XCompose") in
  *Defaults*) open_in_editor ~/.config/uwsm/default ;;
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && hiarchy-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && hiarchy-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && hiarchy-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && hiarchy-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && hiarchy-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && hiarchy-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

  if [ -f ~/.local/state/hiarchy/toggles/suspend-on ]; then
    options="$options¾░Æ▓  Disable Suspend"
  else
    options="$options¾░Æ▓  Enable Suspend"
  fi

  if hiarchy-hibernation-available; then
    options="$options\n¾░żü  Disable Hibernate"
  else
    options="$options\n¾░żü  Enable Hibernate"
  fi

  case $(menu "System" "$options") in
  *Suspend*) hiarchy-toggle-suspend ;;
  *"Enable Hibernate"*) present_terminal hiarchy-hibernation-setup ;;
  *"Disable Hibernate"*) present_terminal hiarchy-hibernation-remove ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "¾░Żć  Package\n¾░Żć  AUR\n’ē©  Web App\n’Æē  TUI\n’Æć  Tailscale\nŅ»Å  Style\n¾░Ź▓  Windows") in
  *Package*) terminal hiarchy-pkg-install ;;
  *AUR*) terminal hiarchy-pkg-aur-install ;;
  *Web*) present_terminal hiarchy-webapp-install ;;
  *TUI*) present_terminal hiarchy-tui-install ;;
  *Tailscale*) present_terminal hiarchy-install-tailscale ;;
  *Style*) show_install_style_menu ;;
  *Windows*) present_terminal "hiarchy-windows-vm install" ;;
  *) show_main_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "¾░Ėī  Theme\n’ĆŠ  Background\nŅÖÖ  Font") in
  *Theme*) present_terminal hiarchy-theme-install ;;
  *Background*) hiarchy-theme-bg-install ;;
  *Font*) show_install_font_menu ;;
  *) show_install_menu ;;
  esac
}

show_install_font_menu() {
  case $(menu "Install" "ŅÖÖ  Meslo LG Mono\nŅÖÖ  Fira Code\nŅÖÖ  Victor Code\nŅÖÖ  Bistream Vera Mono\nŅÖÖ  Iosevka" "--width 350") in
  *Meslo*) install_font "Meslo LG Mono" "ttf-meslo-nerd" "MesloLGL Nerd Font" ;;
  *Fira*) install_font "Fira Code" "ttf-firacode-nerd" "FiraCode Nerd Font" ;;
  *Victor*) install_font "Victor Code" "ttf-victor-mono-nerd" "VictorMono Nerd Font" ;;
  *Bistream*) install_font "Bistream Vera Code" "ttf-bitstream-vera-mono-nerd" "BitstromWera Nerd Font" ;;
  *Iosevka*) install_font "Iosevka" "ttf-iosevka-nerd" "Iosevka Nerd Font Mono" ;;
  *) show_install_menu ;;
  esac
}

show_update_menu() {
  case $(menu "Update" "ŅżĆ Hiarchy\nŅśĢ  Config\n¾░Ėī  Extra Themes\nŅ«ó  Process\n¾░ćģ  Hardware\nŅ®Ė  Firmware\nŅ¼æ  Password\nŅ¼ü  Timezone\nŅÄā  Time") in
  *Hiarchy*) present_terminal hiarchy-update ;;
  *Config*) show_update_config_menu ;;
  *Themes*) present_terminal hiarchy-theme-update ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Firmware*) present_terminal hiarchy-update-firmware ;;
  *Timezone*) present_terminal hiarchy-tz-select ;;
  *Time*) present_terminal hiarchy-update-time ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

show_update_process_menu() {
  case $(menu "Restart" "’ŹÖ  Hypridle\n’ŹÖ  Hyprsunset\n’ŹØ  Swayosd\n¾░ī¦  Walker\n¾░Ź£  Waybar") in
  *Hypridle*) hiarchy-restart-hypridle ;;
  *Hyprsunset*) hiarchy-restart-hyprsunset ;;
  *Swayosd*) hiarchy-restart-swayosd ;;
  *Walker*) hiarchy-restart-walker ;;
  *Waybar*) hiarchy-restart-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "’ŹÖ  Hyprland\n’ŹÖ  Hypridle\n’ŹÖ  Hyprlock\n’ŹÖ  Hyprsunset\n¾▒Ż┤  Plymouth\n’ŹØ  Swayosd\n¾░ī¦  Walker\n¾░Ź£  Waybar") in
  *Hyprland*) present_terminal hiarchy-refresh-hyprland ;;
  *Hypridle*) present_terminal hiarchy-refresh-hypridle ;;
  *Hyprlock*) present_terminal hiarchy-refresh-hyprlock ;;
  *Hyprsunset*) present_terminal hiarchy-refresh-hyprsunset ;;
  *Plymouth*) present_terminal hiarchy-refresh-plymouth ;;
  *Swayosd*) present_terminal hiarchy-refresh-swayosd ;;
  *Walker*) present_terminal hiarchy-refresh-walker ;;
  *Waybar*) present_terminal hiarchy-refresh-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "ŅśĖ  Audio\n¾▒ÜŠ  Wi-Fi\n¾░é»  Bluetooth") in
  *Audio*) present_terminal hiarchy-restart-pipewire ;;
  *Wi-Fi*) present_terminal hiarchy-restart-wifi ;;
  *Bluetooth*) present_terminal hiarchy-restart-bluetooth ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "Ņ¼æ  Drive Encryption\nŅ¼æ  User") in
  *Drive*) present_terminal hiarchy-drive-set-password ;;
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  hiarchy-launch-about
}

show_system_menu() {
  local options="’ĆŻ  Lock\n¾▒ää  Screensaver"
  [ -f ~/.local/state/hiarchy/toggles/suspend-on ] && options="$options\n¾░Æ▓  Suspend"
  hiarchy-hibernation-available && options="$options\n¾░żü  Hibernate"
  options="$options\n¾░£ē  Restart\n¾░Éź  Shutdown"

  case $(menu "System" "$options") in
  *Lock*) hiarchy-lock-screen ;;
  *Screensaver*) hiarchy-launch-screensaver force ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Restart*) hiarchy-cmd-reboot ;;
  *Shutdown*) hiarchy-cmd-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "¾░Ć╗  Apps\n¾░¦æ  Learn\n¾▒ō×  Trigger\nŅ»Å  Style\nŅśĢ  Setup\n¾░ēē  Install\n’ĆĪ  Update\nŅ®┤  About\n’Ćæ  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "LaunchŌĆ”" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *share*) show_share_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenshot*) show_screenshot_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/hiarchy/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
