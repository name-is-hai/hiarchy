  case $(menu "Restart" "ïچ™  Hypridle\nïچ™  Hyprsunset\nïچ‌  Swayosd\nَ°Œ§  Walker\nَ°چœ  Waybar") in
  *Hypridle*) hiarchy-restart-hypridle ;;
  *Hyprsunset*) hiarchy-restart-hyprsunset ;;
