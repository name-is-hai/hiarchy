#!/bin/bash

# Overwrite all the user configs in ~/.config/hypr with the Hiarchy defaults.

hiarchy-refresh-config hypr/autostart.conf
hiarchy-refresh-config hypr/bindings.conf
hiarchy-refresh-config hypr/input.conf
hiarchy-refresh-config hypr/looknfeel.conf
hiarchy-refresh-config hypr/hyprland.conf
