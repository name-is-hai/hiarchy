#!/bin/bash

set -e

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch tagwindow +noidle &> /dev/null || true

# Capture update logs
exec > >(tee "/tmp/hiarchy-update.log") 2>&1

# Perform all update steps
hiarchy-update-time
hiarchy-update-keyring
hiarchy-update-available-reset
hiarchy-update-system-pkgs
hiarchy-migrate
hiarchy-update-aur-pkgs
hiarchy-update-orphan-pkgs
hiarchy-hook post-update

hiarchy-update-analyze-logs

hiarchy-update-restart

# Re-enable screensaver/sleep after updates
hyprctl dispatch tagwindow -- -noidle &> /dev/null || true
