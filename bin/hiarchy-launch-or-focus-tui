#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like hiarchy-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.hiarchy.$(basename "$1")"
LAUNCH_COMMAND="hiarchy-launch-tui $@"

exec hiarchy-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
